<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/exp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="10dp">

    <!-- أيقونة المفضلة على اليمين -->
    <ImageView
        android:id="@+id/ivFavorite"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:src="@drawable/ic_fav1_foreground"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Favorite Icon"/>

    <!-- العلم واسم الدولة -->
    <LinearLayout
        android:id="@+id/countryLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toStartOf="@id/ivFavorite"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivCountry"
            android:layout_width="54dp"
            android:layout_height="39dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_launcher_foreground" />

        <TextView
            android:id="@+id/tvCountryName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Country Name"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- المعلومات + صورة التراك -->
    <LinearLayout
        android:id="@+id/infoLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/countryLayout"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">

        <!-- المعلومات -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvEXP"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="exp"
                android:textSize="20sp" />

        </LinearLayout>

        <!-- صورة التراك على اليمين -->
        <ImageView
            android:id="@+id/ivStadiumImage"
            android:layout_width="150dp"
            android:layout_height="100dp"
            android:scaleType="fitCenter"/>
    </LinearLayout>

</RelativeLayout>