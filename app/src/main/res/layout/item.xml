<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1C1C1C"
    android:padding="8dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="6dp"
        android:backgroundTint="#333333"
        card_view:cardCornerRadius="12dp"
        card_view:cardElevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <!-- Text section -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTrackName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="Track Name"
                    android:textColor="#CCCCCC"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvRaceDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Race Distance:"
                    android:textColor="#AAAAAA"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvFirstGrandPrix"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="First Grand Prix:"
                    android:textColor="#AAAAAA"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvNumberOfLaps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Laps:"
                    android:textColor="#AAAAAA"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvCountry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Country:"
                    android:textColor="#AAAAAA"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Image + Favorite overlay -->
            <FrameLayout
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center_vertical">

                <ImageView
                    android:id="@+id/ivStadiumImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_launcher_foreground" />

                <ImageView
                    android:id="@+id/ivFavoriteIcon"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="8dp"
                    android:clickable="true"
                    android:contentDescription="Favorite Star"
                    android:focusable="true"
                    android:src="@drawable/ic_star"
                    tools:ignore="TouchTargetSizeCheck" />

            </FrameLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>