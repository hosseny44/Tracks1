<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Profile Image -->
        <ImageView
            android:id="@+id/Profile"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginTop="40dp"
            android:src="@drawable/ic_launcher_foreground"
            android:scaleType="centerCrop"
            android:background="@drawable/profile_circle_border" />

        <!-- Name -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Racer Name"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <!-- Email -->
        <TextView
            android:id="@+id/tvEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="racer@email.com"
            android:textSize="16sp"
            android:textColor="#BBBBBB" />

        <!-- Favorite Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnfav1"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="35dp"
            android:text="🏁 My Favorites"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_race_red" />

        <!-- Call Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/BtnCall"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:text="📞 Support"
            android:textStyle="bold"
            android:textColor="#000000"
            android:background="@drawable/btn_race_yellow" />

        <!-- Settings Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btsSet"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:text="⚙ Settings"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_race_dark" />

    </LinearLayout>

</ScrollView>